      "action" : "formula",
      "sources" : [ "LOAD_PL_ORGB" ],
      "parameters" : {
        "expressionType" : "SQL",
        "fields" : [ {
          "type" : "TEXT",
          "name" : "SourceOrg",
          "label" : "SourceOrg",
          "formulaExpression" : "'OrgB'",
          "precision" : 255,
          "defaultValue" : "OrgB"
        } ]
      }
    },
    "APPEND_MULTIORG" : {
