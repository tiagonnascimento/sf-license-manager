        "dataset" : {
          "type" : "connectedDataset",
          "label" : "LM_ProductLicense__c (Org B, PLACEHOLDER connection - does not exist)",
          "connectionName" : "ORG_B_CONNECTION_PLACEHOLDER",
          "sourceObjectName" : "LM_ProductLicense__c"
        },
        "sampleDetails" : {
          "type" : "TopN",
          "sortBy" : [ ]
        },
        "preserveCurrencyFields" : [ ]
      }
    },
