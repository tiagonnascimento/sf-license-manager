uctLicensePurchaseUtilization\"; idle = filter idle by 'SourceOrg' in {{coalesce(column(SourceOrg_Selector.selection, [\"SourceOrg\"]), column(SourceOrg_Selector.result, [\"SourceOrg\"])).asString()}}; idle = filter idle by 'ProductLicense.AssignmentType__c' != \"Login\" || 'ProductLicense.AssignmentType__c' is null; idle = group idle by ('ProductLicense.Name', 'BoardOfDirectors__c', 'VicePresidency__c'); idle = foreach idle generate 'ProductLicense.Name' as 'License', 'BoardOfDirectors__c' as 'Board', 'VicePresidency__c' as 'VicePresidency', \"Idle Licenses\" as 'Category', (sum('Quantity__c') - sum('Assignment.AssignedByPurchase')) as 'Licenses'; q = union used, idle; q = order q by 'License' asc; q = limit q 1000;","receiveFacetSource":{"mode":"all","steps":[]},"selectMode":"single","sortable":true,"strings":[],"type":"saql","useExternalFilters":true,"useGlobal":true,"visualizationParameters":{"visualizationType":"hbar"}},"Fin_Metrics_Table":{"broadcastFacet":true,"groups":[],"label":"License Financial Utilization","numbers":[],"query":"q = load \"ProductLicensePurchaseUtilization\"; q = filter q by 'SourceOrg' in {{coalesce(column(SourceOrg_Selector.selection, [\"SourceOrg\"]), column(SourceOrg_Selector.result, [\"SourceOrg\"])).asString()}}; q = filter q by 'ProductLicense.AssignmentType__c' != \"Login\" || 'ProductLicense.AssignmentType__c' is null; q = foreach q generate 'ProductLicense.Name' as 'License', 'BoardOfDirectors__c' as 'Board', 'Assignment.AssignedByPurchase' as 'UsedRow', 'Quantity__c' as 'QtyRow', ('Quantity__c' - 'Assignment.AssignedByPurchase') as 'IdleQtyRow', (('Quantity__c' - 'Assignment.AssignedByPurchase') * (case when 'Quantity__c' > 0 then 'Price__c' / 'Quantity__c' else 0 end)) as 'IdleCostRow', ('Quantity__c' * (case when 'Quantity__c' > 0 then 'Price__c' / 'Quantity__c' else 0 end)) as 'TotalCostRow'; q = filter q by 'License' in {{coalesce(column(Fin_Idle_Cost.selection, [\"License\"]), column(Fin_Idle_Cost.result, [\"License\"])).asString()}}; q = filter q by 'Board' in {{coalesce(column(Fin_Idle_Cost.selection, [\"Board\"]), column(Fin_Idle_Cost.result, [\"Board\"])).asString()}}; q = group q by ('License', 'Board'); q = foreach q generate 'License' as 'License', 'Board' as 'Board', sum('QtyRow') as 'Contracted Licenses', sum('UsedRow') as 'Used Licenses', sum('IdleQtyRow') as 'Idle Licenses', (\"R$ \" + replace(replace(replace(number_to_string(sum('TotalCostRow'), \"#,##0.00\"), \",\", \"|\"), \".\", \",\"), \"|\", \".\")) as 'Total Investment', (\"R$ \" + replace(replace(replace(number_to_string(sum('IdleCostRow'), \"#,##0.00\"), \",\", \"|\"), \".\", \",\"), \"|\", \".\")) as 'Idle Investment', sum('IdleCostRow') as 'IdleCostNum'; q = order q by 'IdleCostNum' desc; q = limit q 200;","receiveFacetSource":{"mode":"all","steps":[]},"selectMode":"single","sortable":true,"strings":[],"type":"saql","useExternalFilters":true,"useGlobal":true,"visualizationParameters":{"visualizationType":"hbar"}},"Add_ons___Available__2":{"broadcastFacet":true,"datasets":[{"name":"ProductLicensesWithUserAssignments"}],"isGlobal":false,"label":"Add-ons - Available vs Assigned with Login ","query":{"aggregateFilters":[],"columnGroups":[],"columnTotals":[],"limit":2000,"orders":[{"name":"ProductLicense.Name","filters":[],"ascending":true},{"name":"SourceOrg","filters":[],"ascending":true}],"rowTotals":[],"sourceFilters":{"ProductLicensesWithUserAssignments":{"filters":[["ProductLicense.Type__c",["Add-on"],"in"],["LastLoginDate__c",[["day",-180],["day",0]],"between"]]}},"sources":[{"columns":[{"field":["avg","ProductLicense.Quantity__c"],"name":"B"},{"field":["count","*"],"name":"A"}],"filters":[],"groups":["ProductLicense.Name","SourceOrg"],"joins":[],"name":"ProductLicensesWithUserAssignments"}]},"receiveFacetSource":{"mode":"all","steps":[]},"selectMode":"single","sortable":true,"type":"aggregateflex","useExternalFilters":true,"useGlobal":true,"visualizationParameters":{"parameters":{"autoFitMode":"keepLabels","b