 as 'IdleQtyRow', (('Quantity__c' - 'Assignment.AssignedByPurchase') * (case when 'Quantity__c' > 0 then 'Price__c' / 'Quantity__c' else 0 end)) as 'IdleCostRow', ('Assignment.AssignedByPurchase' * (case when 'Quantity__c' > 0 then 'Price__c' / 'Quantity__c' else 0 end)) as 'UsedCostRow'; q = group q by ('License', 'Board'); q = foreach q generate 'License' as 'License', 'Board' as 'Board', sum('UsedRow') as 'Used', sum('QtyRow') as 'Contracted', sum('IdleQtyRow') as 'IdleQty', sum('IdleCostRow') as 'IdleCost', sum('UsedCostRow') as 'UsedCost'; q = order q by 'Contracted' desc; q = limit q 50;","receiveFacetSource":{"mode":"all","steps":[]},"selectMode":"single","type":"saql","useGlobal":true,"visualizationParameters":{"visualizationType":"hbar"}}},"widgetStyle":{"backgroundColor":"#FFFFFF","borderColor":"#747474","borderEdges":[],"borderRadius":0,"borderWidth":1},"widgets":{"link_16":{"parameters":{"destinationLink":{"name":"31510662-3fb2-40b0-9857-60d5d2631710"},"destinationType":"page","fontSize":16,"includeState":false,"text":"Add-ons and Login Licenses","textAlignment":"center","textColor":"#6400B6"},"type":"link"},"link_14":{"parameters":{"destinationLink":{"name":"91aa5399-6939-48cc-944f-6a00166273d5"},"destinationType":"page","fontSize":16,"includeState":false,"text":"Named Base Licenses","textAlignment":"center","textColor":"#6400B6"},"type":"link"},"link_13":{"parameters":{"destinationLink":{"name":"b69db324-6c79-41bc-a3e7-b360cbd2c5f5"},"destinationType":"page","fontSize":16,"includeState":false,"text":"User without Logins in 180 days","textAlignment":"center","textColor":"#FFFFFF"},"type":"link"},"link_10":{"parameters":{"destinationLink":{"name":"b69db324-6c79-41bc-a3e7-b360cbd2c5f5"},"destinationType":"page","fontSize":16,"includeState":false,"text":"User without Logins in 180 days","textAlignment":"center","textColor":"#6400B6"},"type":"link"},"link_11":{"parameters":{"destinationLink":{"name":"b69db324-6c79-41bc-a3e7-b360cbd2c5f5"},"destinationType":