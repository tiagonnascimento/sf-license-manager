_c') as 'VicePresidency', first('BoardOfDirectors__c') as 'Board', first('ProductLicense.Name') as 'License', first('PurchaseDate__c') as 'PurchaseDate', sum('Assignment.AssignedByPurchase') as 'Used', first('Quantity__c') as 'Contracted', (first('Quantity__c') - sum('Assignment.AssignedByPurchase')) as 'IdleQty', (\"R$ \" + replace(replace(replace(number_to_string((case when first('Quantity__c') > 0 then first('Price__c') / first('Quantity__c') else 0 end), \"#,##0.00\"), \",\", \"|\"), \".\", \",\"), \"|\", \".\")) as 'UnitPrice', (\"R$ \" + replace(replace(replace(number_to_string((sum('Assignment.AssignedByPurchase') * (case when first('Quantity__c') > 0 then first('Price__c') / first('Quantity__c') else 0 end)), \"#,##0.00\"), \",\", \"|\"), \".\", \",\"), \"|\", \".\")) as 'UsedCost', (\"R$ \" + replace(replace(replace(number_to_string(((first('Quantity__c') - sum('Assignment.AssignedByPurchase')) * (case when first('Quantity__c') > 0 then first('Price__c') / first('Quantity__c') else 0 end)), \"#,##0.00\"), \",\", \"|\"), \".\", \",\"), \"|\", \".\")) as 'IdleCost', ((first('Quantity__c') - sum('Assignment.AssignedByPurchase')) * (case when first('Quantity__c') > 0 then first('Price__c') / first('Quantity__c') else 0 end)) as 'IdleCostNum'; q = order q by 'IdleCostNum' desc; q = limit q 200;","receiveFacetSource":{"mode":"all","steps":[]},"selectMode":"single","type":"saql","useGlobal":true,"visualizationParameters":{"visualizationType":"hbar"}},"Add_ons___Available__2":{"broadcastFacet":true,"datasets":[{"name":"ProductLicensesWithUserAssignments"}],"isGlobal":false,"label":"Add-ons - Available vs Assigned with Login ","query":{"aggregateFilters":[],"columnGroups":[],"columnTotals":[],"limit":2000,"orders":[{"name":"ProductLicense.Name","filters":[],"ascending":true},{"name":"ProductLicense.Org__c","filters":[],"ascending":true}],"rowTotals":[],"sourceFilters":{"ProductLicensesWithUserAssignments":{"filters":[["ProductLicense.Type__c",["Add-on"],"in"],["Last